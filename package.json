{
  "private": true,
  "name": "@anonymous-dev/0x0-workspace",
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "format": "bun run format:lua",
    "format:check": "bun run format:lua:check",
    "format:lua": "stylua apps/0x0.nvim",
    "format:lua:check": "stylua --check apps/0x0.nvim",
    "test:0x0-nvim": "make -C apps/0x0.nvim test",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@johnnymorganz/stylua-bin": "^2.4.0",
    "@types/bun": "^1.3.12",
    "turbo": "^2.5.0",
    "typescript": "^6.0.3"
  },
  "trustedDependencies": [
    "@johnnymorganz/stylua-bin"
  ]
}
