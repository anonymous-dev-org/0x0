{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@anonymous-dev/0x0",
  "version": "7.0.0",
  "description": "HTTP API server for Claude Code and Codex CLIs",
  "type": "module",
  "license": "MIT",
  "bin": {
    "0x0": "./src/index.ts"
  },
  "files": [
    "src/",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "bun run ./src/index.ts",
    "build": "bun run script/build.ts",
    "build:release": "bun run script/build.ts --archive",
    "build:single": "bun run script/build.ts --single",
    "test": "bun test --preload ./test/preload.ts",
    "typecheck": "bun tsc --noEmit",
    "version:patch": "bun run script/version.ts patch",
    "version:minor": "bun run script/version.ts minor",
    "version:major": "bun run script/version.ts major",
    "release": "bun run script/release.ts",
    "publish:manual": "bun run script/publish.ts",
    "prepublishOnly": "bun tsc --noEmit && bun test --preload ./test/preload.ts"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "hono": "4.10.7",
    "hono-openapi": "1.1.2",
    "xdg-basedir": "5.1.0",
    "yargs": "18.0.0",
    "zod": "4.1.8"
  },
  "devDependencies": {
    "@tsconfig/bun": "1.0.9",
    "@types/bun": "1.3.8",
    "@types/yargs": "17.0.33",
    "typescript": "5.8.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/anonymous-dev-org/0x0"
  },
  "homepage": "https://github.com/anonymous-dev-org/0x0#readme",
  "bugs": {
    "url": "https://github.com/anonymous-dev-org/0x0/issues"
  },
  "keywords": [
    "completion",
    "ai",
    "code",
    "neovim",
    "lsp",
    "claude",
    "codex"
  ]
}
